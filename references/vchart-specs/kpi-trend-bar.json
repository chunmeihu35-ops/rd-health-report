{
  "_meta": {
    "name": "KPI趋势柱状图",
    "description": "月度需求交付数量趋势，6个月，当月高亮，顶部label显示数值",
    "usage": "替换 data.values 和高亮月份即可复用",
    "version": "1.0.0"
  },
  "spec": {
    "type": "bar",
    "data": [
      {
        "id": "barData",
        "values": [
          { "month": "2025-10", "value": 3, "highlight": false },
          { "month": "2025-11", "value": 7, "highlight": false },
          { "month": "2025-12", "value": 7, "highlight": false },
          { "month": "2026-01", "value": 10, "highlight": false },
          { "month": "2026-02", "value": 6, "highlight": false },
          { "month": "2026-03", "value": 8, "highlight": true }
        ]
      }
    ],
    "xField": "month",
    "yField": "value",
    "bar": {
      "style": {
        "cornerRadius": [4, 4, 0, 0],
        "fill": {
          "field": "highlight",
          "scale": "highlightScale"
        }
      }
    },
    "scales": [
      {
        "id": "highlightScale",
        "type": "ordinal",
        "domain": [false, true],
        "range": ["#5090c5", "#2d7eb5"]
      }
    ],
    "label": {
      "visible": true,
      "position": "top",
      "style": {
        "fill": "#335e83",
        "fontSize": 13,
        "fontWeight": 600
      }
    },
    "tooltip": {
      "trigger": "mark",
      "mark": {
        "title": { "visible": true },
        "content": [
          { "key": "交付数量", "value": "{value} 个" }
        ]
      }
    },
    "axes": [
      {
        "orient": "bottom",
        "label": { "visible": true, "style": { "fill": "#506c8a", "fontSize": 11 } }
      },
      {
        "orient": "left",
        "visible": false
      }
    ],
    "crosshair": {
      "xField": {
        "visible": true,
        "line": { "type": "rect", "style": { "fill": "rgba(45,126,181,0.08)" } }
      }
    }
  }
}
